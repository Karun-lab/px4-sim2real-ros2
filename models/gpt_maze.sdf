      <link name="link">
        <collision name="col"><geometry><box><size>6.5 0.2 3</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>6.5 0.2 3</size></box></geometry>
          <material>
            <ambient>0.3 0.6 1.0 1</ambient>
              <diffuse>0.4 0.7 1.0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="m5">
      <static>true</static>
      <pose>0 -6.5 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 7 3</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.2 7 3</size></box></geometry>
          <material>
            <ambient>0.3 0.6 1.0 1</ambient>
              <diffuse>0.4 0.7 1.0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="m6">
      <static>true</static>
      <pose>-7 -7 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>6 0.2 3</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>6 0.2 3</size></box></geometry>
          <material>
            <ambient>0.3 0.6 1.0 1</ambient>
              <diffuse>0.4 0.7 1.0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="m7">
      <static>true</static>
      <pose>7 5 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 10 3</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.2 10 3</size></box></geometry>
          <material>
            <ambient>0.3 0.6 1.0 1</ambient>
              <diffuse>0.4 0.7 1.0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="m8">
      <static>true</static>
      <pose>7 -7 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 6 3</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.2 6 3</size></box></geometry>
          <material>
            <ambient>0.3 0.6 1.0 1</ambient>
              <diffuse>0.4 0.7 1.0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="m9">
      <static>true</static>
      <pose>-4 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 8 3</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.2 8 3</size></box></geometry>
          <material>
            <ambient>0.3 0.6 1.0 1</ambient>
